# StructSim Backend 环境变量示例

# Flask
FLASK_ENV=development
APP_PORT=6060

# 主业务库
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/sim_ai_paltform

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_KEY_PREFIX=mso:
REDIS_DEFAULT_TTL=3600

# 安全密钥
SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret

# Gunicorn
GUNICORN_WORKERS=2
GUNICORN_THREADS=8
GUNICORN_TIMEOUT=180
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100

# 跨域
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 文件上传
UPLOAD_FOLDER=/optdb/upload_dir/opti_issue
MAX_FILE_SIZE=4294967296
CHUNK_SIZE=5242880

# 本地登录 / SSO
AUTH_ENABLE_SSO=false
AUTH_SSO_LOGIN_URL=
AUTH_SSO_REDIRECT_URI=
AUTH_COMPANY_PASSWORD_VERIFY_URL=
AUTH_COMPANY_PASSWORD_VERIFY_METHOD=POST
AUTH_COMPANY_PASSWORD_VERIFY_TIMEOUT=8
AUTH_GET_USER_INFO_URL=
AUTH_GET_USER_INFO_METHOD=GET
AUTH_GET_USER_INFO_TIMEOUT=8
# 用户信息接口固定携带：
# 1. domain_account
# 2. 上一步验密接口返回的 access_token
# 后端同时会额外补一个 Authorization: Bearer <access_token>
AUTH_DEFAULT_ROLE_CODE=GUEST
AUTH_GET_USER_RESOURCE_POOLS_URL=
AUTH_GET_USER_RESOURCE_POOLS_METHOD=GET
AUTH_GET_USER_RESOURCE_POOLS_TIMEOUT=8
# 不配置内网资源池接口时，后端将直接返回 mock 资源池；配置了接口但调用失败时，也会回退到 mock 资源池
AUTH_USE_FAKE_USER_RESOURCE_POOLS=true
# 默认示例：资源池列表 [{"id":19,"name":"OPTI"},{"id":23,"name":"HPC-CPU"},{"id":31,"name":"GPU-POOL"}]，默认资源池 19
AUTH_FAKE_USER_RESOURCE_POOLS_JSON={"source_list":[{"id":19,"name":"OPTI"},{"id":23,"name":"HPC-CPU"},{"id":31,"name":"GPU-POOL"}],"default_source_id":19}
AUTH_COMPANY_UID_INFO_URL=
AUTH_COMPANY_UID_EXPIRE_SECONDS=1800
AUTH_COMPANY_APP_ID=
AUTH_COMPANY_SECRET_CREDIT=

# 测试账号直登
AUTH_ALLOW_TEST_ACCOUNT_BYPASS=false
AUTH_TEST_BYPASS_USERS=

# 登录口令 RSA-OAEP 配置
# 二选一即可：直接填 PEM 文本，或通过路径挂载文件
AUTH_LOGIN_RSA_PUBLIC_KEY=
AUTH_LOGIN_RSA_PRIVATE_KEY=
AUTH_LOGIN_RSA_PUBLIC_KEY_PATH=
AUTH_LOGIN_RSA_PRIVATE_KEY_PATH=
AUTH_LOGIN_RSA_KEY_ID=default

# 外部 MySQL 5.6 只读接入
# 用于项目阶段、输出 component 字典、优化结果聚合
EXTERNAL_MYSQL_HOST=localhost
EXTERNAL_MYSQL_PORT=3306
EXTERNAL_MYSQL_USER=root
EXTERNAL_MYSQL_PASSWORD=replace-with-real-password
EXTERNAL_MYSQL_CHARSET=utf8mb4
EXTERNAL_MYSQL_CONNECT_TIMEOUT=10
EXTERNAL_MYSQL_READ_TIMEOUT=20
EXTERNAL_MYSQL_WRITE_TIMEOUT=20

EXTERNAL_MYSQL_SCHEMA_SIMULATION_PROJECT=simulation_project
EXTERNAL_MYSQL_SCHEMA_STRUCT_MODULE=struct_module
EXTERNAL_MYSQL_SCHEMA_UNION_OPT_KERNAL=union_opt_kernal
EXTERNAL_MYSQL_SCHEMA_UNION_OPT_CONF=union_opt_conf
EXTERNAL_MYSQL_SCHEMA_SQRS_HW=sqrs_hw

# 自动升级开关
AUTO_USER_DEPARTMENT_UPGRADE=true
AUTO_PLATFORM_FEATURES_UPGRADE=true
AUTO_ORDER_PHASE_UPGRADE=true
