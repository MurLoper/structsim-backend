# 力学多场景仿真&优化平台 - 后端环境配置
# 复制此文件为 .env 并根据实际环境修改配置

# Flask 环境
FLASK_ENV=development

# 密钥配置（生产环境必须修改！）
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# 主数据库配置
# SQLite (开发环境默认)
# DATABASE_URL=sqlite:///sim_ai_paltform.db

# MySQL (生产环境推荐)
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/sim_ai_paltform

# PostgreSQL (备选方案)
# DATABASE_URL=postgresql://user:password@localhost:5432/sim_ai_paltform

# MySQL 5.6 低版本数据库配置（用于订单结果查询）
# 连接到内网共享数据库，查询历史订单结果数据
LEGACY_MYSQL_URL=mysql+pymysql://username:password@192.168.1.100:3306/legacy_orders?charset=utf8mb4

# 文件上传配置
# 使用多台内网服务器统一挂载的共享存储路径（绝对路径）
# 文件将按日期自动创建子目录存储，例如：/optdb/upload_dir/opti_issue/2026/03/13/
UPLOAD_FOLDER=/optdb/upload_dir/opti_issue
# 最大文件大小限制（字节），默认 4GB
MAX_FILE_SIZE=4294967296
# 分片大小（字节），默认 5MB
CHUNK_SIZE=5242880

# CORS 跨域配置
# 允许的前端访问地址，多个地址用逗号分隔
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Redis 缓存配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# Redis 键前缀
REDIS_KEY_PREFIX=mso:
# 默认缓存过期时间（秒），默认 1 小时
REDIS_DEFAULT_TTL=3600

# 认证模式配置
# true: 启用SSO并跳转公司SSO；false: 使用本地登录页(域账号+密码)
AUTH_ENABLE_SSO=false
# 公司SSO登录入口，如 http://login.company.com/login1
AUTH_SSO_LOGIN_URL=
# SSO登录成功后的回调地址，如 http://localhost:3000/#/callback
AUTH_SSO_REDIRECT_URI=

# 公司密码校验接口（后端调用，密码不落库）
AUTH_COMPANY_PASSWORD_VERIFY_URL=
AUTH_COMPANY_PASSWORD_VERIFY_METHOD=POST
AUTH_COMPANY_PASSWORD_VERIFY_TIMEOUT=8

# 公司UID换取用户信息接口（SSO callback）
AUTH_COMPANY_UID_INFO_URL=
AUTH_COMPANY_UID_EXPIRE_SECONDS=1800
AUTH_COMPANY_APP_ID=
AUTH_COMPANY_SECRET_CREDIT=

# 测试账号直登开关
# 仅建议开发/测试环境启用；开启后，白名单内且数据库已存在的账号可跳过密码校验直接登录
AUTH_ALLOW_TEST_ACCOUNT_BYPASS=false
# 多个域账号用英文逗号分隔，例如 z00012345,lwx0045644
AUTH_TEST_BYPASS_USERS=

# users.department -> users.department_id 自动升级开关
AUTO_USER_DEPARTMENT_UPGRADE=true
